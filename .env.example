# ===== KeyHub 配置示例 =====
# 复制为 .env 并修改后使用。.env 文件已被 .gitignore 排除，不会被提交。

# 运行环境: development | production
KEYHUB_ENV=development

# 服务监听地址与端口
KEYHUB_HOST=127.0.0.1
KEYHUB_PORT=8000

# 数据库文件路径（SQLite）
KEYHUB_DB_PATH=data/keyhub.db

# 主密码（首次启动用于派生主密钥；生产环境建议通过环境变量注入而非写入文件）
# 留空时首次启动会进入交互式初始化流程
KEYHUB_MASTER_PASSWORD=

# Argon2 派生参数（仅初始化时使用，后续不可更改）
KEYHUB_ARGON2_TIME_COST=3
KEYHUB_ARGON2_MEMORY_COST=65536
KEYHUB_ARGON2_PARALLELISM=4

# Session / Token 签名密钥（留空则启动时随机生成，重启后旧 token 失效）
KEYHUB_SECRET_KEY=

# API Token 有效期（小时），用于程序化访问
KEYHUB_TOKEN_EXPIRE_HOURS=720

# LLM 代理上游连接超时（秒）
KEYHUB_LLM_TIMEOUT=120

# 轮换检查间隔（秒），后台任务
KEYHUB_ROTATION_CHECK_INTERVAL=3600

# 凭证默认过期提醒提前天数
KEYHUB_ROTATION_WARN_DAYS=7

# Web UI 是否启用
KEYHUB_WEB_UI=true
