# ===== KeyHub 配置示例 =====
# 复制为 .env 并修改后使用。.env 文件已被 .gitignore 排除，不会被提交。
# 所有配置项均以 KEYHUB_ 为前缀。

# ===== 基础配置 =====

# 运行环境: development | production
KEYHUB_ENV=development

# 服务监听地址与端口
# 生产环境建议绑定 127.0.0.1，通过反向代理（nginx/Caddy）暴露 HTTPS
KEYHUB_HOST=127.0.0.1
KEYHUB_PORT=8000

# 数据库文件路径（SQLite）
KEYHUB_DB_PATH=data/keyhub.db

# ===== 安全配置 =====

# 主密码（首次启动用于派生主密钥；生产环境建议通过环境变量注入而非写入文件）
# 留空时首次访问 Web UI 或执行 keyhub init 会进入交互式初始化流程
KEYHUB_MASTER_PASSWORD=

# Argon2id 密钥派生参数（仅首次初始化时使用，后续不可更改）
# memory_cost 单位为 KiB，131072 = 128 MiB（推荐值，抗 GPU 破解）
# time_cost=3, parallelism=4 在现代 CPU 上约 300-500ms
KEYHUB_ARGON2_TIME_COST=3
KEYHUB_ARGON2_MEMORY_COST=131072
KEYHUB_ARGON2_PARALLELISM=4

# Session / API Token 签名密钥（PEPPER）
# ⚠️ 生产环境必须设置！留空则每次启动随机生成，重启后所有旧 Token/Session 失效
# 推荐生成方式: python -c "import secrets; print(secrets.token_urlsafe(48))"
KEYHUB_SECRET_KEY=

# API Token 默认有效期（小时），0 = 永不过期
KEYHUB_TOKEN_EXPIRE_HOURS=720

# 空闲自动锁定（秒），0 = 禁用
# 超过该时间无 API 请求则自动锁定，内存中的主密钥被清零
KEYHUB_AUTO_LOCK_IDLE_SECONDS=1800

# API Token 速率限制（每分钟请求数），0 = 禁用
KEYHUB_TOKEN_RPM_LIMIT=60

# ===== LLM 代理配置 =====

# LLM 上游连接/读取超时（秒）
KEYHUB_LLM_CONNECT_TIMEOUT=10
KEYHUB_LLM_READ_TIMEOUT=120

# 响应缓存 TTL（秒），0 = 禁用
# 相同请求（模型+消息+参数）的响应在内存中缓存，减少重复 API 调用
KEYHUB_LLM_CACHE_TTL=300

# 负载均衡策略: round_robin / weighted / latency / cost / least_used
# - round_robin: 轮询（默认）
# - weighted: 按 Key 的 weight 权重分配
# - latency: 按历史延迟选最快的 Key
# - cost: 优先选成本最低的 Key
# - least_used: 选当前在飞请求最少的 Key（推荐高并发场景）
KEYHUB_LLM_BALANCE_STRATEGY=round_robin

# 跨 Provider 降级: 同 Provider 无可用 Key 时，尝试其他 Provider 同名模型
# 例如 openai/gpt-4 熔断后，尝试 deepseek/gpt-4（需该 Key 的 label/model 匹配）
KEYHUB_LLM_ENABLE_CROSS_PROVIDER_FALLBACK=false

# 每 Key RPM 限制（每分钟请求数），0 = 不限
# 超过限制的 Key 将被暂时跳过
KEYHUB_LLM_KEY_RPM_LIMIT=0

# 每 Key TPM 限制（每分钟 Token 数），0 = 不限
KEYHUB_LLM_KEY_TPM_LIMIT=0

# LLM 代理最大并发请求数，0 = 不限
# 超过并发数的请求将排队等待
KEYHUB_LLM_MAX_CONCURRENT=0

# ===== 轮换与审计 =====

# 后台轮换检查间隔（秒），默认 3600 = 1 小时
KEYHUB_ROTATION_CHECK_INTERVAL=3600

# 凭证到期前提前提醒天数
KEYHUB_ROTATION_WARN_DAYS=7

# 审计日志保留天数，0 = 永久保留
# 超过天数的审计日志将在启动时自动清理
KEYHUB_AUDIT_RETENTION_DAYS=0

# ===== Web UI =====

# 是否启用 Web UI（禁用后仅保留 REST API）
KEYHUB_WEB_UI=true

# ===== 通知配置 =====
# 轮换提醒、异常事件可通过 Webhook 或邮件推送

# Webhook（POST JSON body，可选 HMAC-SHA256 签名）
# 签名通过 X-KeyHub-Signature 请求头传递（sha256=hex_hmac）
KEYHUB_NOTIFY_WEBHOOK_URL=
KEYHUB_NOTIFY_WEBHOOK_SECRET=

# 邮件通知（SMTP）
KEYHUB_NOTIFY_EMAIL_ENABLED=false
KEYHUB_NOTIFY_EMAIL_SMTP_HOST=
KEYHUB_NOTIFY_EMAIL_SMTP_PORT=587
KEYHUB_NOTIFY_EMAIL_SMTP_USER=
KEYHUB_NOTIFY_EMAIL_SMTP_PASSWORD=
KEYHUB_NOTIFY_EMAIL_FROM=
# 多个收件人用逗号分隔
KEYHUB_NOTIFY_EMAIL_TO=
